{
  "name": "woc-bike",
  "version": "1.0.0",
  "description": "Website for the Carbondale Bike Project",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^5.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/forms": "^0.4.0-alpha.2",
    "@tailwindcss/typography": "^0.5.0-alpha.3",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.13"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.13"
  },
  "scripts": {
    "build:css": "postcss src/stylev3.css -o _site/assets/css/stylev3.css",
    "build:production": "eleventy && npm run build:css",
    "build:dev": "eleventy && npm run build:css",
    "build": "npm run build:production",
    "dev": "concurrently \"postcss src/stylev3.css -o _site/assets/css/stylev3.css --watch\" \"eleventy --serve\"",
    "start": "npm run dev",
    "test": "playwright test",
    "webp": "node src/js/utils/convert-to-webp.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sethlbrown/woc-bike.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sethlbrown/woc-bike/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
